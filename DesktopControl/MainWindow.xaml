<Window x:Class="DesktopControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DesktopControl"
        Title="Desktop Control"
        Height="650"
        Width="1250"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0b0b15">

    <Window.Resources>

        <local:StatusToColorConverter x:Key="StatusToColorConverter"/>

        <LinearGradientBrush x:Key="MainGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0f0f1f" Offset="0"/>
            <GradientStop Color="#1c1c3a" Offset="1"/>
        </LinearGradientBrush>

        <!-- Button -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#5c5cff"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Glass -->
        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background" Value="#22ffffff"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.25"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Foreground" Value="#aaaaee"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource MainGradient}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="25">
            <TextBlock Text="💻" FontSize="32" Margin="0,0,12,0"/>
            <TextBlock Text="Desktop Control"
                       FontSize="28"
                       Foreground="White"
                       FontWeight="SemiBold"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Margin="20">

            <DataGrid x:Name="ComputersGrid"
                      AutoGenerateColumns="False"
                      ItemsSource="{Binding Komputery}"
                      Background="Transparent"
                      Foreground="White"
                      BorderThickness="0"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      RowBackground="Transparent"
                      AlternatingRowBackground="#10ffffff"
                      HorizontalAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Margin" Value="0,6"/>
                        <Setter Property="Background" Value="#25ffffff"/>

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridRow">
                                    <Border x:Name="rowBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="12"
                                            Padding="6">
                                        <DataGridCellsPresenter/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="rowBorder" Property="Background" Value="#35ffffff"/>
                                        </Trigger>

                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="rowBorder" Property="Background" Value="#5050ff"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="MAC Address" Binding="{Binding MAC}" Width="2*"/>
                    <DataGridTextColumn Header="IP Address" Binding="{Binding IP}" Width="2*"/>
                    <DataGridTextColumn Header="Online" Binding="{Binding Onl}" Width="*"/>

                    <DataGridTemplateColumn Header="Akcje" Width="3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                    <Button Content="Włącz"
                                            Click="BtnPowerOn_Click"
                                            Style="{StaticResource ModernButton}"
                                            Background="#43a047"/>

                                    <Button Content="Wyłącz"
                                            Click="BtnPowerOff_Click"
                                            Style="{StaticResource ModernButton}"
                                            Background="#e53935"/>

                                    <Button Content="Podgląd"
                                            Click="Preview_Click"
                                            Style="{StaticResource ModernButton}"
                                            Background="#1e88e5"/>

                                    <Button Click="Btn_Lock"
                                            Background="#8e24aa">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                                                <Setter Property="Content" Value="Zablokuj"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                        <Setter Property="Content" Value="Odblokuj"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Status / Błąd" Width="3*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#30ffffff"
                                        CornerRadius="10"
                                        Padding="8">
                                    <TextBlock Text="{Binding Error}"
                                               Foreground="{Binding Error, Converter={StaticResource StatusToColorConverter}}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="20">
            <Button x:Name="BtnDetectComputers"
                    Content="Wykryj komputery"
                    Width="220"
                    Height="45"
                    Click="WykryjKomputery"
                    Style="{StaticResource ModernButton}"
                    Background="#6a1b9a"/>
        </StackPanel>

    </Grid>
</Window>